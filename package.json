{
  "name": "jam-spotify",
  "version": "1.0.0",
  "description": "Collaborative Spotify Queue System",
  "scripts": {
    "install-all": "npm install --include=dev && npm install --prefix backend --include=dev && npm install --prefix frontend --include=dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "start": "npm start --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
