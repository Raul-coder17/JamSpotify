# Puerto del servidor backend
PORT=3000

# Credenciales de Spotify Developer Dashboard
# Obténlas en https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=TU_CLIENT_ID_AQUI
SPOTIFY_CLIENT_SECRET=TU_CLIENT_SECRET_AQUI

# Debe coincidir exactamente con el Redirect URI registrado en Spotify Developer Dashboard
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/callback
